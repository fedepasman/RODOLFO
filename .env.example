# ============================================================================
# Plantilla de variables de entorno. Copiar a .env.local y completar.
#   cp .env.example .env.local
# NUNCA poner valores reales en este archivo (se versiona en git).
# ============================================================================

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave PRIVILEGIADA: bypassa RLS. Solo servidor. NUNCA con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# Las siguientes credenciales viven en n8n (self-hosted), NO en esta webapp.
# Se listan acá solo como referencia de lo que necesita el sistema completo:
#   - N8N_ENCRYPTION_KEY        (n8n: cifra las credenciales guardadas)
#   - TELEGRAM_BOT_TOKEN        (n8n: bot de notificaciones)
#   - TELEGRAM_CHAT_ID          (n8n: destino de las notificaciones)
#   - GMAIL / SMTP credentials  (n8n: envío de emails)
# ============================================================================
